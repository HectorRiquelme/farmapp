<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="FarmApp.Presentation.Controls.MiniMapView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        StrokeShape="RoundRectangle 14"
        StrokeThickness="1"
        Stroke="{StaticResource ColorSeparador}"
        BackgroundColor="{StaticResource ColorSurface}"
        HeightRequest="230">

        <Grid>
            <!-- WebView del mapa Leaflet -->
            <WebView
                x:Name="MapWebView"
                Navigating="OnMapNavigating"
                Navigated="OnMapNavigated"
                BackgroundColor="{StaticResource ColorBackground}" />

            <!-- Indicador de carga inicial -->
            <ActivityIndicator
                x:Name="LoadingIndicator"
                IsRunning="True"
                IsVisible="True"
                Color="{StaticResource ColorAbiertaAhora}"
                HorizontalOptions="Center"
                VerticalOptions="Center" />

            <!-- Hint: toca un pin -->
            <Label
                x:Name="HintLabel"
                Text="Toca un pin para centrar"
                FontSize="11"
                TextColor="{StaticResource ColorTextoSecundario}"
                BackgroundColor="#80000000"
                Padding="8,4"
                IsVisible="False"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,8,8" />
        </Grid>
    </Border>

</ContentView>
