<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FarmApp.Presentation.Pages.DetallePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FarmApp.Presentation.ViewModels"
    xmlns:controls="clr-namespace:FarmApp.Presentation.Controls"
    x:DataType="vm:DetalleFarmaciaViewModel"
    BackgroundColor="{AppThemeBinding Dark={StaticResource ColorBackground}, Light={StaticResource ColorBackgroundLight}}"
    Title="{Binding Farmacia.Nombre}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="16,8,16,32">

            <!-- Badge de estado -->
            <controls:EstadoBadge
                Estado="{Binding Farmacia.Estado}"
                Tipo="{Binding Farmacia.Tipo}"
                HorizontalOptions="Start"
                Margin="0,8,0,16" />

            <!-- Nombre -->
            <Label
                Text="{Binding Farmacia.Nombre}"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Dark={StaticResource ColorTextoPrimario}, Light={StaticResource ColorTextoPrimarioLight}}"
                Margin="0,0,0,4" />

            <!-- Tipo -->
            <Label
                Text="{Binding Farmacia.TipoTexto}"
                FontSize="14"
                TextColor="{AppThemeBinding Dark={StaticResource ColorTextoSecundario}, Light={StaticResource ColorTextoSecundarioLight}}"
                Margin="0,0,0,24" />

            <!-- Separador -->
            <BoxView HeightRequest="1" Color="{AppThemeBinding Dark={StaticResource ColorSeparador}, Light={StaticResource ColorSeparadorLight}}" Margin="0,0,0,20" />

            <!-- Dirección -->
            <Grid ColumnDefinitions="24,*" Margin="0,0,0,16">
                <Label Grid.Column="0" Text="📍" FontSize="18" VerticalOptions="Start" />
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label
                        Text="{Binding Farmacia.Direccion}"
                        FontSize="16"
                        TextColor="{AppThemeBinding Dark={StaticResource ColorTextoPrimario}, Light={StaticResource ColorTextoPrimarioLight}}" />
                    <Label
                        Text="{Binding Farmacia.Comuna}"
                        FontSize="14"
                        TextColor="{AppThemeBinding Dark={StaticResource ColorTextoSecundario}, Light={StaticResource ColorTextoSecundarioLight}}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Horario -->
            <Grid ColumnDefinitions="24,*" Margin="0,0,0,16">
                <Label Grid.Column="0" Text="🕐" FontSize="18" />
                <Label
                    Grid.Column="1"
                    Text="{Binding Farmacia.HorarioTexto}"
                    FontSize="16"
                    TextColor="{AppThemeBinding Dark={StaticResource ColorTextoPrimario}, Light={StaticResource ColorTextoPrimarioLight}}"
                    VerticalOptions="Center" />
            </Grid>

            <!-- Teléfono (solo si está disponible) -->
            <Grid ColumnDefinitions="24,*" Margin="0,0,0,16" IsVisible="{Binding TieneTelefono}">
                <Label Grid.Column="0" Text="📞" FontSize="18" />
                <Label
                    Grid.Column="1"
                    Text="{Binding Farmacia.Telefono}"
                    FontSize="16"
                    TextColor="{AppThemeBinding Dark={StaticResource ColorTextoPrimario}, Light={StaticResource ColorTextoPrimarioLight}}"
                    VerticalOptions="Center" />
            </Grid>

            <!-- Distancia -->
            <Grid ColumnDefinitions="24,*" Margin="0,0,0,16" IsVisible="{Binding TieneCoordenadas}">
                <Label Grid.Column="0" Text="📏" FontSize="18" />
                <Label
                    Grid.Column="1"
                    Text="{Binding Farmacia.DistanciaTexto}"
                    FontSize="16"
                    TextColor="{AppThemeBinding Dark={StaticResource ColorTextoSecundario}, Light={StaticResource ColorTextoSecundarioLight}}"
                    VerticalOptions="Center" />
            </Grid>

            <!-- Separador -->
            <BoxView HeightRequest="1" Color="{AppThemeBinding Dark={StaticResource ColorSeparador}, Light={StaticResource ColorSeparadorLight}}" Margin="0,8,0,24" />

            <!-- Acciones principales -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,12">

                <Button
                    Grid.Column="0"
                    Text="Llamar"
                    Command="{Binding LlamarFarmaciaCommand}"
                    IsVisible="{Binding TieneTelefono}"
                    BackgroundColor="{StaticResource ColorAbiertaAhora}"
                    TextColor="White"
                    CornerRadius="14"
                    HeightRequest="56"
                    FontSize="16"
                    FontAttributes="Bold" />

                <Button
                    Grid.Column="0"
                    Text="Sin teléfono"
                    IsVisible="{Binding TieneTelefono, Converter={StaticResource InvertBoolConverter}}"
                    IsEnabled="False"
                    BackgroundColor="{StaticResource ColorCerrada}"
                    TextColor="White"
                    CornerRadius="14"
                    HeightRequest="56"
                    FontSize="16" />

                <Button
                    Grid.Column="1"
                    Text="Navegar"
                    Command="{Binding NavegarAFarmaciaCommand}"
                    BackgroundColor="{StaticResource ColorNavegacion}"
                    TextColor="White"
                    CornerRadius="14"
                    HeightRequest="56"
                    FontSize="16"
                    FontAttributes="Bold" />

            </Grid>

            <!-- Copiar dirección -->
            <Button
                Text="Copiar dirección"
                Command="{Binding CopiarDireccionCommand}"
                BackgroundColor="Transparent"
                BorderColor="{AppThemeBinding Dark={StaticResource ColorSeparador}, Light={StaticResource ColorSeparadorLight}}"
                BorderWidth="1"
                TextColor="{AppThemeBinding Dark={StaticResource ColorTextoPrimario}, Light={StaticResource ColorTextoPrimarioLight}}"
                CornerRadius="14"
                HeightRequest="48"
                FontSize="15" />

            <!-- Fuente de datos -->
            <Label
                Text="{Binding FuenteConsultaTexto}"
                FontSize="12"
                HorizontalOptions="Center"
                Margin="0,24,0,0"
                TextColor="{AppThemeBinding Dark={StaticResource ColorTextoSecundario}, Light={StaticResource ColorTextoSecundarioLight}}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
