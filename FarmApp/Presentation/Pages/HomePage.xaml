<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FarmApp.Presentation.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FarmApp.Presentation.ViewModels"
    x:DataType="vm:HomeViewModel"
    BackgroundColor="{AppThemeBinding Dark={StaticResource ColorBackground}, Light={StaticResource ColorBackgroundLight}}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto, Auto, *" Padding="28,0">

        <!-- ════════════════════════════════════════════════ -->
        <!--   BLOQUE DE IDENTIDAD / LOGO FARMAPP             -->
        <!--   Animado en OnAppearing (fade + scale)          -->
        <!-- ════════════════════════════════════════════════ -->
        <VerticalStackLayout
            x:Name="LogoBranding"
            Grid.Row="1"
            Spacing="0"
            HorizontalOptions="Center">

            <!-- Logo mark: imagen SVG + texto FARMAPP en línea -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">

                <!-- Pin clásico + cruz farmacéutica (ratio 168:216 ≈ 0.78) -->
                <Image
                    Source="logo_farmapp.svg"
                    WidthRequest="56"
                    HeightRequest="72"
                    Aspect="AspectFit"
                    VerticalOptions="Center" />

                <!-- Wordmark FARMAPP -->
                <Label
                    Text="FARMAPP"
                    FontSize="44"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Dark={StaticResource ColorTextoPrimario}, Light={StaticResource ColorTextoPrimarioLight}}"
                    VerticalOptions="Center"
                    CharacterSpacing="2" />

            </HorizontalStackLayout>

            <!-- Producto / subtítulo -->
            <Label
                Text="Farmacia de Turno Nocturno"
                FontSize="17"
                HorizontalOptions="Center"
                TextColor="{StaticResource ColorAbiertaAhora}"
                Margin="0,10,0,0" />

            <!-- Tagline -->
            <Label
                Text="Tu turno. Tu farmacia. Ahora."
                FontSize="15"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                TextColor="{AppThemeBinding Dark={StaticResource ColorTextoSecundario}, Light={StaticResource ColorTextoSecundarioLight}}"
                Margin="0,6,0,0" />

            <!-- Separador decorativo -->
            <BoxView
                HeightRequest="1"
                Color="{AppThemeBinding Dark={StaticResource ColorSeparador}, Light={StaticResource ColorSeparadorLight}}"
                Margin="40,18,40,18"
                HorizontalOptions="Fill" />

            <!-- Tags: TURNO · URGENCIA · CERCANA -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Label Text="TURNO"    FontSize="11" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Dark={StaticResource ColorTagCategoria}, Light={StaticResource ColorTagCategoriaLight}}" />
                <Label Text="·"        FontSize="11"
                       TextColor="{AppThemeBinding Dark={StaticResource ColorTagCategoria}, Light={StaticResource ColorTagCategoriaLight}}" />
                <Label Text="URGENCIA" FontSize="11" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Dark={StaticResource ColorTagCategoria}, Light={StaticResource ColorTagCategoriaLight}}" />
                <Label Text="·"        FontSize="11"
                       TextColor="{AppThemeBinding Dark={StaticResource ColorTagCategoria}, Light={StaticResource ColorTagCategoriaLight}}" />
                <Label Text="CERCANA"  FontSize="11" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Dark={StaticResource ColorTagCategoria}, Light={StaticResource ColorTagCategoriaLight}}" />
            </HorizontalStackLayout>

        </VerticalStackLayout>

        <!-- ════════════════════════════════════════════════ -->
        <!--   BLOQUE DE ACCIÓN (botón + errores)             -->
        <!--   Animado con slide-up en OnAppearing            -->
        <!-- ════════════════════════════════════════════════ -->
        <VerticalStackLayout
            x:Name="ActionSection"
            Grid.Row="2"
            Spacing="14"
            Margin="0,28,0,0">

            <!-- Aviso: permiso de ubicación denegado -->
            <Frame
                IsVisible="{Binding TienePermiso, Converter={StaticResource InvertBoolConverter}}"
                BackgroundColor="{AppThemeBinding Dark={StaticResource ColorErrorFondo}, Light={StaticResource ColorErrorFondoLight}}"
                BorderColor="{AppThemeBinding Dark={StaticResource ColorErrorBorde}, Light={StaticResource ColorErrorBordeLight}}"
                CornerRadius="14"
                Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="Necesitamos tu ubicación para encontrar la farmacia más cercana."
                        FontSize="14"
                        TextColor="{AppThemeBinding Dark={StaticResource ColorErrorTexto}, Light={StaticResource ColorErrorTextoLight}}"
                        HorizontalTextAlignment="Center" />
                    <Button
                        Text="Permitir ubicación"
                        Command="{Binding SolicitarPermisoCommand}"
                        BackgroundColor="{AppThemeBinding Dark={StaticResource ColorErrorBoton}, Light={StaticResource ColorErrorBotonLight}}"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="44"
                        FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <!-- BOTÓN PRINCIPAL -->
            <Button
                Text="Buscar ahora"
                Command="{Binding BuscarFarmaciasCommand}"
                IsEnabled="{Binding NoEstaCargando}"
                BackgroundColor="{StaticResource ColorAbiertaAhora}"
                TextColor="White"
                CornerRadius="18"
                HeightRequest="66"
                FontSize="18"
                FontAttributes="Bold" />

            <!-- Spinner de carga -->
            <ActivityIndicator
                IsRunning="{Binding EstaCargando}"
                IsVisible="{Binding EstaCargando}"
                Color="{StaticResource ColorAbiertaAhora}"
                HorizontalOptions="Center" />

            <!-- Mensaje de error -->
            <Frame
                IsVisible="{Binding TieneError}"
                BackgroundColor="{AppThemeBinding Dark={StaticResource ColorErrorFondo}, Light={StaticResource ColorErrorFondoLight}}"
                BorderColor="{AppThemeBinding Dark={StaticResource ColorErrorBorde}, Light={StaticResource ColorErrorBordeLight}}"
                CornerRadius="12"
                Padding="14">
                <Label
                    Text="{Binding MensajeError}"
                    FontSize="14"
                    TextColor="{AppThemeBinding Dark={StaticResource ColorErrorTexto}, Light={StaticResource ColorErrorTextoLight}}"
                    HorizontalTextAlignment="Center" />
            </Frame>

        </VerticalStackLayout>

        <!-- ════════════════════════════════════════════════ -->
        <!--   PIE DE PÁGINA                                  -->
        <!-- ════════════════════════════════════════════════ -->
        <VerticalStackLayout
            Grid.Row="3"
            VerticalOptions="End"
            HorizontalOptions="Center"
            Spacing="3"
            Margin="0,0,0,22">
            <Label
                Text="Datos oficiales MINSAL · Chile"
                FontSize="12"
                HorizontalOptions="Center"
                TextColor="{AppThemeBinding Dark={StaticResource ColorTextoSecundario}, Light={StaticResource ColorTextoSecundarioLight}}" />
            <Label
                Text="Solo uso informativo · No reemplaza atención médica"
                FontSize="11"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                TextColor="{AppThemeBinding Dark={StaticResource ColorTextoSutil}, Light={StaticResource ColorTextoSutilLight}}" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
